# Copy to `.env.local` for local development (gitignored).
#
# Gemura Admin Web uses the same NestJS backend and database as Gemura Web.
# Point NEXT_PUBLIC_API_URL at the same API base you use for apps/gemura-web
# (backend global prefix is `/api`; see backend/src/main.ts).

NEXT_PUBLIC_API_URL=http://localhost:3004/api
NEXT_PUBLIC_SITE_URL=http://localhost:3015
