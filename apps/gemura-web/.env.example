# Copy to .env.local for local development:
#   cp .env.example .env.local
#
# During `next dev`, you can omit this line to use same-origin `/api` (rewrites → localhost:3004).
# Or set an explicit URL (same as gemura-admin-web):
NEXT_PUBLIC_API_URL=http://localhost:3004/api
#
# Production (same-origin via Nginx proxy):
# NEXT_PUBLIC_API_URL=https://app.gemura.rw/api
