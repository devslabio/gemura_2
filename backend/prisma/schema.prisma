  name        String   @unique
  description String?
  is_active   Boolean  @default(true) @map("is_active")
  sort_order  Int      @default(0) @map("sort_order")
  created_at  DateTime @default(now()) @map("created_at")
  updated_at  DateTime @updatedAt @map("updated_at")

  @@index([is_active])
  @@index([sort_order])
  @@map("milk_rejection_reasons")
}

// ============================================
// INVENTORY ITEM TYPES (predefined list for selection)
// ============================================

model InventoryItemCategory {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?  @db.Text
  sort_order  Int      @default(0) @map("sort_order")
  created_at  DateTime @default(now()) @map("created_at")
  updated_at  DateTime @updatedAt @map("updated_at")

  // Relations
  items InventoryItem[]

  @@index([sort_order])
  @@map("inventory_item_categories")
}

model InventoryItem {
  id          String   @id @default(uuid()) @db.Uuid
  category_id String   @map("category_id") @db.Uuid
  name        String
  code        String?  // Optional short code (e.g. MILK-1L)
  unit        String?  // e.g. L, kg, pcs
  description String?  @db.Text
  is_active   Boolean  @default(true) @map("is_active")
  sort_order  Int      @default(0) @map("sort_order")
  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  // Relations
  category InventoryItemCategory @relation(fields: [category_id], references: [id], onDelete: Restrict)
  products Product[]

  @@index([category_id])
  @@index([is_active])
  @@index([sort_order])
  @@map("inventory_items")
}

// ============================================
// INVENTORY SALES MODULE
// ============================================

model InventorySale {
  id              String                      @id @default(uuid()) @db.Uuid
  product_id      String                      @map("product_id") @db.Uuid
  order_id        String?                     @map("order_id") @db.Uuid // Nullable: Links to Order if from online marketplace
  buyer_type      InventorySaleBuyerType      @map("buyer_type")
  buyer_account_id String?                    @map("buyer_account_id") @db.Uuid // Required for 'supplier', nullable for 'customer'/'other'
  buyer_name      String?                     @map("buyer_name") // Optional for new clients
  buyer_phone     String?                     @map("buyer_phone") // Optional for new clients
  quantity        Decimal                     @db.Decimal(10, 2)
  unit_price      Decimal                     @map("unit_price") @db.Decimal(10, 2)
  total_amount    Decimal                     @map("total_amount") @db.Decimal(10, 2)
  amount_paid     Decimal                     @default(0) @map("amount_paid") @db.Decimal(10, 2)
  payment_status  InventorySalePaymentStatus  @default(unpaid) @map("payment_status")
  sale_date       DateTime                    @map("sale_date")
  notes           String?                     @db.Text
  created_at      DateTime                    @default(now()) @map("created_at")
  updated_at      DateTime                    @updatedAt @map("updated_at")
  created_by      String?                     @map("created_by") @db.Uuid

  // Relations
  product           Product                     @relation("InventorySaleProduct", fields: [product_id], references: [id], onDelete: Restrict)
  order             Order?                      @relation("InventorySaleOrder", fields: [order_id], references: [id], onDelete: SetNull) // Link to marketplace order
  buyer_account     Account?                    @relation("InventorySaleBuyer", fields: [buyer_account_id], references: [id], onDelete: SetNull) // For buyer (supplier/customer) - also used for supplier debt tracking
  created_by_user   User?                       @relation("InventorySaleCreatedBy", fields: [created_by], references: [id], onDelete: SetNull)
  payroll_deductions PayrollDeduction[]          // Settled via payroll deduction when supplier owes for inventory

  @@index([product_id])
  @@index([order_id]) // For linking to marketplace orders
  @@index([buyer_account_id])
  @@index([buyer_type])
  @@index([payment_status])
  @@index([sale_date])
  @@map("inventory_sales")
}

// ============================================
// INVENTORY MOVEMENTS (audit trail for stock changes)
// ============================================

model InventoryMovement {
  id               String                         @id @default(uuid()) @db.Uuid
  product_id       String                         @map("product_id") @db.Uuid
  movement_type    InventoryMovementType          @map("movement_type")
  quantity         Int                            // Always positive; direction from movement_type
  reference_type   InventoryMovementReferenceType @map("reference_type")
  reference_id     String?                        @map("reference_id") @db.Uuid // e.g. inventory_sale.id
  description      String?                        @db.Text // e.g. "Sale to John (A_ABC)", "New shipment"
  unit_price       Decimal?                       @map("unit_price") @db.Decimal(10, 2)
  created_at       DateTime                       @default(now()) @map("created_at")
  created_by       String?                        @map("created_by") @db.Uuid

  // Relations
  product        Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
  created_by_user User?  @relation("InventoryMovementCreatedBy", fields: [created_by], references: [id], onDelete: SetNull)

  @@index([product_id])
  @@index([movement_type])
  @@index([reference_type])
  @@index([created_at])
  @@map("inventory_movements")
}

// ============================================
// LOANS MODULE (money lending – generic borrower)
// ============================================

model Loan {
  id                   String    @id @default(uuid()) @db.Uuid
  lender_account_id    String    @map("lender_account_id") @db.Uuid   // MCC / your account
  borrower_type        String    @map("borrower_type")              // supplier, customer, other
  borrower_account_id  String?   @map("borrower_account_id") @db.Uuid // Required for supplier/customer; null for other
  borrower_name        String?   @map("borrower_name")              // For "other" or display
  principal            Decimal   @db.Decimal(15, 2)
  amount_repaid        Decimal   @default(0) @map("amount_repaid") @db.Decimal(15, 2)
  currency             String    @default("RWF")
  status               String    @default("active")                // active, closed
  disbursement_date    DateTime  @map("disbursement_date")
  due_date             DateTime? @map("due_date")
  notes                String?   @db.Text
  created_at           DateTime  @default(now()) @map("created_at")
  updated_at           DateTime  @updatedAt @map("updated_at")
  created_by           String?   @map("created_by") @db.Uuid

  // Relations
  lender_account    Account             @relation("LoanLender", fields: [lender_account_id], references: [id], onDelete: Cascade)
  borrower_account  Account?            @relation("LoanBorrower", fields: [borrower_account_id], references: [id], onDelete: SetNull)
  payroll_deductions PayrollDeduction[]
  repayments        LoanRepayment[]

  @@index([lender_account_id])
  @@index([borrower_account_id])
  @@index([borrower_type])
  @@index([status])
  @@index([disbursement_date])
  @@map("loans")
}

model LoanRepayment {
  id               String   @id @default(uuid()) @db.Uuid
  loan_id          String   @map("loan_id") @db.Uuid
  amount           Decimal  @db.Decimal(15, 2)
  repayment_date   DateTime @map("repayment_date")
  notes            String?  @db.Text
  source           String   @default("direct") // direct | payroll
  created_at       DateTime @default(now()) @map("created_at")

  loan Loan @relation(fields: [loan_id], references: [id], onDelete: Cascade)

  @@index([loan_id])
  @@index([repayment_date])
  @@map("loan_repayments")
}

// Single table for admin hierarchy (province, district, sector, cell, village) – mirrors dsacco m01_adm.adm_location
model Location {
  id            String       @id @default(uuid()) @db.Uuid
  code          String       @db.VarChar(30)
  name          String       @db.VarChar(255)
  location_type LocationType @map("location_type")
  parent_id     String?      @map("parent_id") @db.Uuid

  parent   Location?   @relation("LocationParent", fields: [parent_id], references: [id], onDelete: Restrict)
  children Location[]  @relation("LocationParent")
  farms    Farm[]

  @@unique([code])
  @@index([location_type])
  @@index([parent_id])
  @@map("locations")
}

model Farm {
  id           String      @id @default(uuid()) @db.Uuid
  account_id   String      @map("account_id") @db.Uuid
  name         String
  code         String?     @unique
  description  String?     @db.Text
  location     String?     // legacy / extra address line
  location_id  String?     @map("location_id") @db.Uuid
  status       FarmStatus  @default(active)
  created_at   DateTime    @default(now()) @map("created_at")
  updated_at   DateTime    @updatedAt @map("updated_at")
  created_by   String?     @map("created_by") @db.Uuid

  account  Account   @relation("FarmAccount", fields: [account_id], references: [id], onDelete: Cascade)
  locationRef Location? @relation(fields: [location_id], references: [id], onDelete: SetNull)
  animals               Animal[]
  milk_productions      MilkProduction[]
  farm_species_focus    FarmSpeciesFocus[]
  poultry_flocks        PoultryFlock[]
  pig_batches           PigBatch[]
  pig_farrowings        PigFarrowing[]

  @@index([account_id])
  @@index([location_id])
  @@index([status])
  @@map("farms")
}

/** Optional: species + modes (multi-select farms). Used for nav / feature gates. */
model FarmSpeciesFocus {
  farm_id    String               @map("farm_id") @db.Uuid
  species_id String               @map("species_id") @db.Uuid
  modes      FarmProductionMode[]

  farm    Farm    @relation(fields: [farm_id], references: [id], onDelete: Cascade)
  species Species @relation(fields: [species_id], references: [id], onDelete: Cascade)

  @@id([farm_id, species_id])
  @@index([species_id])
  @@map("farm_species_focus")
}

// ============================================
// Orora: Animal module (multi-species livestock)
// ============================================

model Species {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique
  name        String
  description String?  @db.Text
  sort_order  Int      @default(0) @map("sort_order")
  created_at  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  breeds             Breed[]
  animals            Animal[]
  farm_species_focus FarmSpeciesFocus[]

  @@index([code])
  @@map("species")
}

// Predefined breeds (select on registration/edit); scoped by species
model Breed {
  id          String   @id @default(uuid()) @db.Uuid
  species_id  String   @map("species_id") @db.Uuid
  name        String
  code        String   @unique
  description String?  @db.Text
  created_at  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  species        Species @relation(fields: [species_id], references: [id], onDelete: Restrict)
  animals        Animal[]
  poultry_flocks PoultryFlock[]
  pig_batches    PigBatch[]

  @@index([code])
  @@index([species_id])
  @@map("breeds")
}

model Animal {
  id             String        @id @default(uuid()) @db.Uuid
  account_id     String        @map("account_id") @db.Uuid
  farm_id        String?       @map("farm_id") @db.Uuid
  species_id     String        @map("species_id") @db.Uuid
  breed_id      String        @map("breed_id") @db.Uuid
  tag_number     String        @map("tag_number")
  name           String?
  gender         AnimalGender
  date_of_birth  DateTime      @map("date_of_birth")
  source         AnimalSource
  purchase_date  DateTime?     @map("purchase_date")
  purchase_price Decimal?      @map("purchase_price") @db.Decimal(10, 2)
  mother_id      String?       @map("mother_id") @db.Uuid
  father_id      String?       @map("father_id") @db.Uuid
  status         AnimalStatus  @default(active)
  photo_url      String?       @map("photo_url")
  notes          String?       @db.Text
  created_at     DateTime      @default(now()) @map("created_at")
  updated_at     DateTime      @updatedAt @map("updated_at")
  created_by     String?       @map("created_by") @db.Uuid

  account        Account         @relation("AnimalAccount", fields: [account_id], references: [id], onDelete: Cascade)
  species        Species         @relation(fields: [species_id], references: [id], onDelete: Restrict)
  breed          Breed           @relation(fields: [breed_id], references: [id], onDelete: Restrict)
  farm           Farm?           @relation(fields: [farm_id], references: [id], onDelete: SetNull)
  mother         Animal?         @relation("AnimalMother", fields: [mother_id], references: [id], onDelete: SetNull)
  father          Animal?         @relation("AnimalFather", fields: [father_id], references: [id], onDelete: SetNull)
  offspring_mother Animal[]      @relation("AnimalMother")
  offspring_father Animal[]      @relation("AnimalFather")
  weights         AnimalWeight[]
  health_records  AnimalHealth[]
  milk_sales      MilkSale[]
  milk_productions MilkProduction[]
  breeding_records AnimalBreeding[]  @relation("AnimalBreedingDam")
  breeding_as_bull AnimalBreeding[]  @relation("AnimalBreedingBull")
  calvings         AnimalCalving[]   @relation("AnimalCalvingMother")
  calving_as_calf  AnimalCalving?    @relation("AnimalCalvingCalf")
  pig_farrowings_as_sow PigFarrowing[] @relation("SowFarrowing")

  @@unique([account_id, tag_number])
  @@index([account_id])
  @@index([species_id])
  @@index([breed_id])
  @@index([farm_id])
  @@index([status])
  @@index([gender])
  @@map("animals")
}

model AnimalWeight {
  id          String   @id @default(uuid()) @db.Uuid
  animal_id   String   @map("animal_id") @db.Uuid
  weight_kg   Decimal  @map("weight_kg") @db.Decimal(6, 2)
  recorded_at DateTime @map("recorded_at")
  notes       String?  @db.Text
  created_at  DateTime @default(now()) @map("created_at")
  created_by  String?  @map("created_by") @db.Uuid

  animal Animal @relation(fields: [animal_id], references: [id], onDelete: Cascade)

  @@index([animal_id])
  @@index([recorded_at])
  @@map("animal_weights")
}

model AnimalHealth {
  id               String          @id @default(uuid()) @db.Uuid
  animal_id        String          @map("animal_id") @db.Uuid
  event_type       HealthEventType @map("event_type")
  event_date       DateTime        @map("event_date")
  description      String          @db.Text
  diagnosis        String?         @db.Text
  treatment        String?         @db.Text
  medicine_name    String?         @map("medicine_name")
  dosage           String?
  administered_by  String?         @map("administered_by")
  vet_user_id      String?         @map("vet_user_id") @db.Uuid
  vet_first_name   String?         @map("vet_first_name")
  vet_last_name    String?         @map("vet_last_name")
  vet_phone        String?         @map("vet_phone")
  next_due_date    DateTime?       @map("next_due_date")
  cost             Decimal?        @db.Decimal(10, 2)
  notes            String?         @db.Text
  created_at       DateTime        @default(now()) @map("created_at")
  created_by       String?         @map("created_by") @db.Uuid

  animal  Animal @relation(fields: [animal_id], references: [id], onDelete: Cascade)
  vetUser User?  @relation("VetUserAnimalHealth", fields: [vet_user_id], references: [id], onDelete: SetNull)

  @@index([animal_id])
  @@index([event_type])
  @@index([event_date])
  @@index([next_due_date])
  @@index([vet_user_id])
  @@map("animal_health")
}

model AnimalBreeding {
  id                    String          @id @default(uuid()) @db.Uuid
  animal_id             String          @map("animal_id") @db.Uuid
  breeding_date         DateTime        @map("breeding_date") @db.Date
  heat_date             DateTime?       @map("heat_date") @db.Date
  method                BreedingMethod
  bull_animal_id        String?         @map("bull_animal_id") @db.Uuid
  bull_name             String?         @map("bull_name")
  semen_code            String?         @map("semen_code")
  expected_calving_date DateTime?       @map("expected_calving_date") @db.Date
  outcome               BreedingOutcome? @default(unknown)
  notes                 String?         @db.Text
  created_at            DateTime        @default(now()) @map("created_at")
  created_by            String?         @map("created_by") @db.Uuid

  animal    Animal  @relation("AnimalBreedingDam", fields: [animal_id], references: [id], onDelete: Cascade)
  bull_animal Animal? @relation("AnimalBreedingBull", fields: [bull_animal_id], references: [id], onDelete: SetNull)

  @@index([animal_id])
  @@index([breeding_date])
  @@index([expected_calving_date])
  @@map("animal_breeding")
}

model AnimalCalving {
  id           String         @id @default(uuid()) @db.Uuid
  mother_id    String         @map("mother_id") @db.Uuid
  calving_date DateTime       @map("calving_date") @db.Date
  calf_id      String?        @unique @map("calf_id") @db.Uuid
  outcome      CalvingOutcome
  gender       AnimalGender?  @map("gender")
  weight_kg    Decimal?       @map("weight_kg") @db.Decimal(6, 2)
  notes        String?        @db.Text
  created_at   DateTime       @default(now()) @map("created_at")
  created_by   String?        @map("created_by") @db.Uuid

  mother Animal  @relation("AnimalCalvingMother", fields: [mother_id], references: [id], onDelete: Cascade)
  calf   Animal? @relation("AnimalCalvingCalf", fields: [calf_id], references: [id], onDelete: SetNull)

  @@index([mother_id])
  @@index([calving_date])
  @@index([calf_id])
  @@map("animal_calving")
}

// ============================================
// Orora: Poultry flocks (eggs, mortality, intake)
// ============================================

model PoultryFlock {
  id                   String             @id @default(uuid()) @db.Uuid
  account_id           String             @map("account_id") @db.Uuid
  farm_id              String?            @map("farm_id") @db.Uuid
  breed_id             String?            @map("breed_id") @db.Uuid
  name                 String
  code                 String?
  started_at           DateTime           @map("started_at") @db.Date
  opening_head_count   Int                @map("opening_head_count")
  current_head_count   Int                @map("current_head_count")
  status               PoultryFlockStatus @default(active)
  notes                String?            @db.Text
  created_at           DateTime           @default(now()) @map("created_at")
  updated_at           DateTime           @updatedAt @map("updated_at")
  created_by           String?            @map("created_by") @db.Uuid

  account Account @relation(fields: [account_id], references: [id], onDelete: Cascade)
  farm    Farm?   @relation(fields: [farm_id], references: [id], onDelete: SetNull)
  breed   Breed?  @relation(fields: [breed_id], references: [id], onDelete: SetNull)

  daily_records FlockDailyRecord[]
  movements     FlockMovement[]

  @@index([account_id])
  @@index([farm_id])
  @@map("poultry_flocks")
}

model FlockDailyRecord {
  id              String   @id @default(uuid()) @db.Uuid
  flock_id        String   @map("flock_id") @db.Uuid
  record_date     DateTime @map("record_date") @db.Date
  eggs_collected  Int      @default(0) @map("eggs_collected")
  mortality_count Int      @default(0) @map("mortality_count")
  notes           String?  @db.Text
  created_at      DateTime @default(now()) @map("created_at")
  updated_at      DateTime @updatedAt @map("updated_at")

  flock PoultryFlock @relation(fields: [flock_id], references: [id], onDelete: Cascade)

  @@unique([flock_id, record_date])
  @@index([record_date])
  @@map("flock_daily_records")
}

model FlockMovement {
  id            String             @id @default(uuid()) @db.Uuid
  flock_id      String             @map("flock_id") @db.Uuid
  movement_date DateTime           @map("movement_date") @db.Date
  type          FlockMovementType
  quantity      Int
  notes         String?            @db.Text
  created_at    DateTime           @default(now()) @map("created_at")
  created_by    String?            @map("created_by") @db.Uuid

  flock PoultryFlock @relation(fields: [flock_id], references: [id], onDelete: Cascade)

  @@index([flock_id])
  @@index([movement_date])
  @@map("flock_movements")
}

// ============================================
// Orora: Pig batches (weights, farrowing)
// ============================================

model PigBatch {
  id                   String         @id @default(uuid()) @db.Uuid
  account_id           String         @map("account_id") @db.Uuid
  farm_id              String?        @map("farm_id") @db.Uuid
  breed_id             String?        @map("breed_id") @db.Uuid
  name                 String
  code                 String?
  started_at           DateTime       @map("started_at") @db.Date
  opening_head_count   Int            @map("opening_head_count")
  current_head_count   Int            @map("current_head_count")
  status               PigBatchStatus @default(active)
  notes                String?        @db.Text
  created_at           DateTime       @default(now()) @map("created_at")
  updated_at           DateTime       @updatedAt @map("updated_at")
  created_by           String?        @map("created_by") @db.Uuid

  account Account @relation(fields: [account_id], references: [id], onDelete: Cascade)
  farm    Farm?   @relation(fields: [farm_id], references: [id], onDelete: SetNull)
  breed   Breed?  @relation(fields: [breed_id], references: [id], onDelete: SetNull)

  weights    PigBatchWeight[]
  farrowings PigFarrowing[]

  @@index([account_id])
  @@index([farm_id])
  @@map("pig_batches")
}

model PigBatchWeight {
  id              String   @id @default(uuid()) @db.Uuid
  batch_id        String   @map("batch_id") @db.Uuid
  weighed_date    DateTime @map("weighed_date") @db.Date
  avg_weight_kg   Decimal  @map("avg_weight_kg") @db.Decimal(8, 2)
  min_weight_kg   Decimal? @map("min_weight_kg") @db.Decimal(8, 2)
  max_weight_kg   Decimal? @map("max_weight_kg") @db.Decimal(8, 2)
  animals_weighed Int?     @map("animals_weighed")
  weight_band     String?  @map("weight_band") @db.VarChar(64)
  notes           String?  @db.Text
  created_at      DateTime @default(now()) @map("created_at")

  batch PigBatch @relation(fields: [batch_id], references: [id], onDelete: Cascade)

  @@unique([batch_id, weighed_date])
  @@map("pig_batch_weights")
}

model PigFarrowing {
  id             String   @id @default(uuid()) @db.Uuid
  account_id     String   @map("account_id") @db.Uuid
  farm_id        String?  @map("farm_id") @db.Uuid
  pig_batch_id   String?  @map("pig_batch_id") @db.Uuid
  sow_animal_id  String?  @map("sow_animal_id") @db.Uuid
  farrowing_date DateTime @map("farrowing_date") @db.Date
  live_born      Int      @default(0) @map("live_born")
  stillborn      Int      @default(0) @map("stillborn")
  mummified      Int      @default(0) @map("mummified")
  notes          String?  @db.Text
  created_at     DateTime @default(now()) @map("created_at")
  created_by     String?  @map("created_by") @db.Uuid

  account Account   @relation(fields: [account_id], references: [id], onDelete: Cascade)
  farm    Farm?     @relation(fields: [farm_id], references: [id], onDelete: SetNull)
  batch   PigBatch? @relation(fields: [pig_batch_id], references: [id], onDelete: SetNull)
  sow     Animal?   @relation("SowFarrowing", fields: [sow_animal_id], references: [id], onDelete: SetNull)

  @@index([account_id])
  @@index([farm_id])
  @@index([pig_batch_id])
  @@map("pig_farrowings")
}
