  charge         Charge?        @relation(fields: [charge_id], references: [id], onDelete: SetNull)

  @@index([payslip_id])
  @@index([deduction_type])
  @@index([inventory_sale_id])
  @@index([loan_id])
  @@index([charge_id])
  @@map("payroll_deductions")
}

