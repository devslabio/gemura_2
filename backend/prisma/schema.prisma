// ============================================

model Charge {
  id                      String    @id @default(uuid()) @db.Uuid
  customer_account_id     String    @map("customer_account_id") @db.Uuid
  name                    String
  description             String?
  kind                    String    // one_time | recurring
  amount_type             String    @map("amount_type") // fixed | percentage
